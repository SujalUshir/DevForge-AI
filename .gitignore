# ─────────────────────────────────────────────
# DevForge AI — .gitignore
# ─────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# uv
# uv.lock
.uv/


# Distribution / packaging
*.whl
*.tar.gz

# Environment variables — NEVER commit secrets
.env
.env.local
.env.*.local

# Pytest / testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# MyPy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Node / npm / pnpm / yarn
node_modules/
.pnpm-store/
yarn-error.log
package-lock.json
pnpm-lock.yaml

# Next.js
apps/frontend/.next/
apps/frontend/out/

# TypeScript
*.tsbuildinfo

# Build output
dist/
build/

# Logs
*.log
logs/
*.log.*

# OS-specific
.DS_Store
Thumbs.db
Desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker
docker-compose.override.yml

# Generated workspace output (project blueprints written to disk)
workspace/

# Temporary files
*.tmp
*.temp