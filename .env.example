# ─────────────────────────────────────────────────────────────────
# DevForge AI — Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_NAME="DevForge AI"
APP_VERSION="1.0.0"
DEBUG=false

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Logging ──────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
# Default: Next.js dev server
CORS_ORIGINS=http://localhost:3000

# ── Storage ──────────────────────────────────────────────────────
# Absolute or relative path where generated project blueprints are written.
# Relative paths resolve from the apps/backend/ directory.
OUTPUT_DIR=./workspace

# ── Google AI ────────────────────────────────────────────────────
# Required for live agent execution. Leave empty to run in mock mode.
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Mock Mode ────────────────────────────────────────────────────
# Set to true to run the pipeline offline without consuming Gemini quota.
# All 11 agents will produce structured placeholder outputs.
MOCK_LLM=false

# ── Agent Limits ─────────────────────────────────────────────────
# Maximum number of times the Engineering Director can request revisions.
MAX_REVISION_ATTEMPTS=2

# Seconds before a single agent execution times out.
AGENT_TIMEOUT_SECONDS=120

# Number of Gemini API retries per agent before the phase is marked FAILED.
AGENT_MAX_RETRIES=3
